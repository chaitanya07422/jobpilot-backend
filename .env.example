PORT=3000
NODE_ENV=development

# MongoDB Atlas / server DB (same as production)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jobpilot?retryWrites=true&w=majority

# Qdrant Cloud (set HEALTH_CHECK_QDRANT=false for local if unused)
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_API_KEY=
HEALTH_CHECK_QDRANT=false

# Redis — local Docker only: docker compose up -d → localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RESEND_API_KEY=
RESEND_FROM_EMAIL=JobPilot <noreply@yourdomain.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
SWAGGER_ENABLED=true

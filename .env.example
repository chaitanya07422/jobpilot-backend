PORT=3000
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jobpilot?retryWrites=true&w=majority

# Qdrant Cloud
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_API_KEY=

# Redis (managed cloud or container in ~/oracle/infra/docker)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
RESEND_API_KEY=
FRONTEND_URL=https://your-app.pages.dev
LOG_LEVEL=info
SWAGGER_ENABLED=true
